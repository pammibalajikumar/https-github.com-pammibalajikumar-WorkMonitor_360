<Window x:Class="WorkMonitor_360.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="WorkMonitor 360°"
        Height="600"
        Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F5F7FA">

    <!--<Window.Resources>
        <Style TargetType="Button">
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>-->
    <!--<Window.Resources>
      <Style TargetType="Button">
          <Setter Property="FontWeight" Value="Bold"/>
      </Style>
  </Window.Resources>-->
 


    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="WorkMonitor 360°"
                   FontSize="28"
                   FontWeight="Bold"
                   Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal"
                    Grid.Row="1"
                    Margin="0,0,0,20">
           
            <!--<Style TargetType="Button">

                </style>-->

                    <Button 
                    Width="107"
                    Height="40"
                    Margin="0,0,40,0"
                     Background="SlateBlue"
                    Foreground="White"
                    BorderThickness="0"
              
                    Command="{Binding CheckInCommand}" >

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="✅"
               FontSize="16"
               Margin="0,0,10,0"
               VerticalAlignment="Center"/>
                            <TextBlock Text="Check In" VerticalAlignment="Center" FontSize="16"/>
                 </StackPanel>   

            </Button>

            <!--<Button Width="50" Height="50">
                <Image Source="/Resources/login.png"
           Width="24"
           Height="24"/>
            </Button>-->


            <Button 
                Width="107"
                Height="40"
                Margin="0,0,40,0"
                Background="SlateBlue"
                Foreground="White"
                BorderThickness="0"
                Command="{Binding CheckOutCommand}" >

              <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⬅"
               FontSize="18"
               Margin="0,0,10,0"
               VerticalAlignment="Center"/>
                    <TextBlock Text="Check Out" VerticalAlignment="Center" FontSize="16"/>
               </StackPanel>

            </Button>

            <!--<Button Content="Sync Data"
                    Width="120"
                    Height="40"
                    Command="{Binding SyncCommand}" />-->

            <Button
                    Width="107"
                    Height="40"
                    Margin="0,0,40,0"
                    Background="SlateBlue"
                    Foreground="White"
                    BorderThickness="0"
                    Command="{Binding SyncCommand}" >

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🔄"
                    FontSize="18"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"/>
                    <TextBlock Text="Sync Data" VerticalAlignment="Center" FontSize="16"/>                   
                    
                </StackPanel>
            </Button>


            <!--<Button x:Name="ReportButton"-->
            <!--<Button Content="Report"-->
           <Button
                     Width="107"
                    Height="40"
                    Margin="0,0,40,0"
                    Background="SlateBlue"
                    Foreground="White"
                    BorderThickness="0"
                   Click="ReportButton_Click" >

                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock Text="📊"
                    FontSize="18"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center"/>
                    <TextBlock Text="Report" VerticalAlignment="Center" FontSize="16"/>
                </StackPanel>
            </Button>
            <Button Width="170"
                    Height="40"
                    Margin="0,0,40,0"
                    Background="SlateBlue"
                    Foreground="white"
                    BorderThickness="0"
                    Click="AIREportButton_Click">

                <StackPanel Orientation="Horizontal">
                    <TextBlock   Text="📈"
                                 Margin="0,0,10,0"
                                 VerticalAlignment="Center"/>
                    <TextBlock Text="AI Analytical Report" VerticalAlignment="Center" FontSize="16"/>

                </StackPanel>      
                            
                            
            </Button>            
            

        </StackPanel>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="10"
                Padding="10">

            <DataGrid ItemsSource="{Binding Sessions}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"  EnableRowVirtualization="True"
                    EnableColumnVirtualization="True"
                    VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling">       

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="FontWeight" Value="Bold"/>
                    </Style>
                  </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>

                    <!--<DataGridTextColumn Header="ID"
                                        Binding="{Binding Id}"
                                        Width="80"/>-->

                    <DataGridTextColumn Header="Serial No"
                    Binding="{Binding SerialNo}"
                    Width="80"/>

                    <DataGridTextColumn Header="Machine Name"
                                        Binding="{Binding MachineName}" FontWeight="Bold"
                                        Width="180"/>

                    <DataGridTextColumn Header="User Name"
                                        Binding="{Binding UserName}"
                                        Width="180"/>

                    <DataGridTextColumn Header="Check In"
                                        Binding="{Binding CheckInTime}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Check Out"
                                        Binding="{Binding CheckOutTime}"
                                        Width="150"/>

                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding Status}"
                                        Width="100"/>

                    <DataGridCheckBoxColumn Header="Synced"
                                            Binding="{Binding Synced}"
                                            Width="100"/>

                </DataGrid.Columns>

            </DataGrid>

        </Border>

    </Grid>
</Window>