<Window x:Class="WorkMonitor_360.View.ReportFilterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WorkMonitor_360.View"
        mc:Ignorable="d"
        Title="ReportFilterWindow" Height="240" Width="400"
        WindowStartupLocation="CenterScreen" >
    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Check-In Start Date"
                       Margin="0,0,0,5"/>

            <DatePicker x:Name="dpStartDate"
                        Margin="0,0,0,15"/>

            <TextBlock Text="Check-In End Date"
                       Margin="0,0,0,5"/>

            <DatePicker x:Name="dpEndDate"
                        Margin="0,0,0,20"/>

            <Button Content="Generate Report"
                    Width="150"
                    Height="35"
                    HorizontalAlignment="Center"
                    Click="GenerateReport_Click"/>

        </StackPanel>

    </Grid>
</Window>
